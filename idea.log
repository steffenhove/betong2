  parts {
    text: "Make suggestions to improve this code:\n```kotlin\npackage no.steffenhove.betongkalkulator\n\nimport android.content.Context\nimport android.content.SharedPreferences\nimport android.os.Bundle\nimport android.util.Log\nimport android.widget.Toast\nimport androidx.activity.compose.setContent\nimport androidx.appcompat.app.AppCompatActivity\nimport androidx.compose.foundation.layout.*\nimport androidx.compose.material.*\nimport androidx.compose.runtime.*\nimport androidx.compose.ui.Modifier\nimport androidx.compose.ui.unit.dp\nimport androidx.preference.PreferenceManager\nimport no.steffenhove.betongkalkulator.ui.FirkantInput\nimport no.steffenhove.betongkalkulator.ui.KjerneInput\nimport no.steffenhove.betongkalkulator.ui.TrekantInput\nimport org.json.JSONArray\nimport org.json.JSONObject\nimport java.time.LocalDateTime\nimport java.time.format.DateTimeFormatter\nimport java.util.Locale\nimport kotlin.math.PI\nimport kotlin.math.sqrt\nimport no.steffenhove.betongkalkulator.Unit\n\ndata class Dimensions(val value: Double, val unit: Unit)\n\ndata class CoreDimensions(val diameter: Dimensions, val height: Dimensions)\n\ndata class SquareDimensions(val length: Dimensions, val width: Dimensions, val thickness: Dimensions)\n\ndata class TriangleDimensions(val sideA: Dimensions, val sideB: Dimensions, val sideC: Dimensions, val thickness: Dimensions)\n\nclass MainActivity : AppCompatActivity() {\n    // Behold KUN denne deklarasjonen p\303\245 klasseniv\303\245:\n    private var resultText by mutableStateOf(\"\") // RIKTIG: Kun \303\251n deklarasjon\n\n    companion object {\n        const val DENSITY_CONCRETE = 2400.0\n        const val DENSITY_LIGHT_CONCRETE = 1800.0\n    }\n\n    private lateinit var prefs: SharedPreferences\n    private lateinit var defaultPrefs: SharedPreferences\n    private var coreVisible by mutableStateOf(true)\n    private var squareVisible by mutableStateOf(false)\n    private var triangleVisible by mutableStateOf(false)\n\n\n    override fun onCreate(savedInstanceState: Bundle?) {\n        super.onCreate(savedInstanceState)\n\n        prefs = getSharedPreferences(\"settings\", Context.MODE_PRIVATE)\n        defaultPrefs = PreferenceManager.getDefaultSharedPreferences(this)\n\n        setContent {\n            val context = this@MainActivity\n            val unitSystem = defaultPrefs.getString(\"unit_preference\", \"Metrisk\") ?: \"Metrisk\"\n\n            // State-variabler for alle input-felt\n            var diameterState by remember { mutableStateOf(0.0) }\n            var heightState by remember { mutableStateOf(0.0) }\n            var lengthState by remember { mutableStateOf(0.0) }\n            var widthState by remember { mutableStateOf(0.0) }\n            var thicknessState by remember { mutableStateOf(0.0) }\n            var aState by remember { mutableStateOf(0.0) }\n            var bState by remember { mutableStateOf(0.0) }\n            var cState by remember { mutableStateOf(0.0) }\n\n            Column(Modifier.padding(16.dp)) {\n                // ... (knapper for \303\245 velge form - denne koden m\303\245 du legge inn selv)\n\n                when {\n                    coreVisible -> KjerneInput(diameterState, heightState, unitSystem) { diameter, height, diameterUnitString, heightUnitString ->\n                        val diameterUnit = Unit.fromString(diameterUnitString)\n                        val heightUnit = Unit.fromString(heightUnitString)\n\n                        if (diameterUnit != null && heightUnit != null) {\n                            val coreDimensions = CoreDimensions(Dimensions(diameter, diameterUnit), Dimensions(height, heightUnit))\n                            resultText = calculateAndSave(context, \"Kjerne\", coreDimensions = coreDimensions)\n                        } else {\n                            resultText = \"Ugyldig enhet valgt for kjerne.\"\n                        }\n                    }\n                    squareVisible -> FirkantInput(lengthState, widthState, thicknessState, unitSystem) { length, width, thickness, lengthUnitString, widthUnitString, thicknessUnitString ->\n                        val lengthUnit = Unit.fromString(lengthUnitString)\n                        val widthUnit = Unit.fromString(widthUnitString)\n                        val thicknessUnit = Unit.fromString(thicknessUnitString)\n\n                        if (lengthUnit != null && widthUnit != null && thicknessUnit != null) {\n                            val squareDimensions = SquareDimensions(Dimensions(length, lengthUnit), Dimensions(width, widthUnit), Dimensions(thickness, thicknessUnit))\n                            resultText = calculateAndSave(context, \"Firkant\", squareDimensions = squareDimensions)\n                        } else {\n                            resultText = \"Ugyldig enhet valgt for firkant.\"\n                        }\n                    }\n                    triangleVisible -> TrekantInput(aState, bState, cState, thicknessState, unitSystem) { a, b, c, thickness, sideAUnitString, sideBUnitString, sideCUnitString, thicknessTriangleUnitString ->\n                        val sideAUnit = Unit.fromString(sideAUnitString)\n                        val sideBUnit = Unit.fromString(sideBUnitString)\n                        val sideCUnit = Unit.fromString(sideCUnitString)\n                        val thicknessTriangleUnit = Unit.fromString(thicknessTriangleUnitString)\n\n                        if (sideAUnit != null && sideBUnit != null && sideCUnit != null && thicknessTriangleUnit != null) {\n                            val triangleDimensions = TriangleDimensions(Dimensions(a, sideAUnit), Dimensions(b, sideBUnit), Dimensions(c, sideCUnit), Dimensions(thickness, thicknessTriangleUnit))\n                            resultText = calculateAndSave(context, \"Trekant\", triangleDimensions = triangleDimensions)\n                        } else {\n                            resultText = \"Ugyldig enhet valgt for trekant.\"\n                        }\n                    }\n                }\n\n                Spacer(Modifier.height(16.dp)) // Denne linjen er n\303\245 tilbake!\n                Text(text = resultText)\n            }\n\n    fun calculateAndSave(\n        context: Context,\n        shape: String,\n        coreDimensions: CoreDimensions? = null,\n        squareDimensions: SquareDimensions? = null,\n        triangleDimensions: TriangleDimensions? = null\n    ): String {\n        var volume = 0.0\n        var weight = 0.0\n        var dimensions = \"\"\n\n        when (shape) {\n            \"Kjerne\" -> {\n                if (coreDimensions != null) {\n                    val diameterMeters = coreDimensions.diameter.value * coreDimensions.diameter.unit.toMeters\n                    val heightMeters = coreDimensions.height.value * coreDimensions.height.unit.toMeters\n                    volume = calculateCylinderVolume(diameterMeters, heightMeters)\n                    weight = calculateWeight(volume)\n                    dimensions = String.format(\n                        Locale.ROOT,\n                        \"Diameter: %.2f %s, H\303\270yde: %.2f %s\",\n                        coreDimensions.diameter.value, coreDimensions.diameter.unit.display, // Corrected access\n                        coreDimensions.height.value, coreDimensions.height.unit.display  // Corrected access\n                    )\n                } else {\n                    return \"Feil: Kjerne dimensjoner er null.\"\n                }\n            }\n            \"Firkant\" -> {\n                if (squareDimensions != null) {\n                    val lengthMeters = squareDimensions.length.value * squareDimensions.length.unit.toMeters\n                    val widthMeters = squareDimensions.width.value * squareDimensions.width.unit.toMeters\n                    val thicknessMeters = squareDimensions.thickness.value * squareDimensions.thickness.unit.toMeters\n                    volume = calculateBoxVolume(lengthMeters, widthMeters, thicknessMeters)\n                    weight = calculateWeight(volume)\n                    dimensions = String.format(\n                        Locale.ROOT,\n                        \"Lengde: %.2f %s, Bredde: %.2f %s, Tykkelse: %.2f %s\",\n                        squareDimensions.length.value, squareDimensions.length.unit.display, // Corrected access\n                        squareDimensions.width.value, squareDimensions.width.unit.display, // Corrected access\n                        squareDimensions.thickness.value, squareDimensions.thickness.unit.display // Corrected access\n                    )\n                } else {\n                    return \"Feil: Firkant dimensjoner er null.\"\n                }\n            }\n            \"Trekant\" -> {\n                if (triangleDimensions != null) {\n                    val sideAMeters = triangleDimensions.sideA.value * triangleDimensions.sideA.unit.toMeters\n                    val sideBMeters = triangleDimensions.sideB.value * triangleDimensions.sideB.unit.toMeters\n                    val sideCMeters = triangleDimensions.sideC.value * triangleDimensions.sideC.unit.toMeters\n                    val thicknessMeters = triangleDimensions.thickness.value * triangleDimensions.thickness.unit.toMeters\n                    volume = calculateTriangleVolume(sideAMeters, sideBMeters, sideCMeters, thicknessMeters)\n                    weight = calculateWeight(volume)\n                    dimensions = String.format(\n                        Locale.ROOT,\n                        \"Side A: %.2f %s, Side B: %.2f %s, Side C: %.2f %s, Tykkelse: %.2f %s\",\n                        triangleDimensions.sideA.value, triangleDimensions.sideA.unit.display, // Corrected access\n                        triangleDimensions.sideB.value, triangleDimensions.sideB.unit.display, // Corrected access\n                        triangleDimensions.sideC.value, triangleDimensions.sideC.unit.display, // Corrected access\n                        triangleDimensions.thickness.value, triangleDimensions.thickness.unit.display // Corrected access\n                    )\n                } else {\n                    return \"Feil: Trekant dimensjoner er null.\"\n                }\n            }\n            else -> return \"Ukjent form\" // Important to handle the else case\n        }\n\n        val calculation = \"$shape: Volum: ${String.format(Locale.ROOT, \"%.2f\", volume)}, Vekt: ${String.format(Locale.ROOT, \"%.0f\", weight)}, $dimensions\"\n\n        saveCalculationToHistory(context, calculation)\n        return calculation\n    }\n        private fun convertToMeters(value: Double, unit: Unit): Double {\n            val unitSystem = defaultPrefs.getString(\"unit_preference\", \"Metrisk\") ?: \"Metrisk\"\n\n            return if (unitSystem == \"Imperial\") {\n                when (unit) {\n                    Unit.INCH -> value * Unit.INCH.toMeters\n                    Unit.FOOT -> value * Unit.FOOT.toMeters\n                    else -> {\n                        Log.e(\"convertToMeters\", \"Ugyldig enhet for Imperial: ${unit.display}. Returnerer 0.0\")\n                        0.0 // Viktig: Returner en standardverdi ved feil\n                    }\n                }\n            } else { // Metrisk system\n                when (unit) {\n                    Unit.MILLIMETER, Unit.CENTIMETER, Unit.METER -> value * unit.toMeters\n                    else -> {\n                        Log.e(\"convertToMeters\", \"Ugyldig enhet for Metrisk: ${unit.display}. Returnerer 0.0\")\n                        0.0 // Viktig: Returner en standardverdi ved feil\n                    }\n                }\n            }\n        }\n\n    private fun calculateCylinderVolume(diameter: Double, height: Double): Double {\n        val radius = diameter / 2\n        return PI * radius * radius * height\n    }\n\n    private fun calculateBoxVolume(length: Double, width: Double, thickness: Double): Double {\n        return length * width * thickness\n    }\n\n    private fun calculateTriangleVolume(sideA: Double, sideB: Double, sideC: Double, thickness: Double): Double {\n        val s = (sideA + sideB + sideC) / 2\n        return try {\n            val area = sqrt(s * (s - sideA) * (s - sideB) * (s - sideC))\n            area * thickness\n        } catch (e: IllegalArgumentException) {\n            Toast.makeText(this, \"Ugyldig trekant\", Toast.LENGTH_SHORT).show()\n            0.0\n        }\n    }\n\n    private fun calculateWeight(volume: Double): Double {\n        val density = when (prefs.getString(\"density_preference\", \"Betong\")) {\n            \"Lettbetong\" -> DENSITY_LIGHT_CONCRETE\n            \"Egendefinert\" -> {\n                val customDensityString = prefs.getString(\"custom_density\", DENSITY_CONCRETE.toString())\n                customDensityString?.toDoubleOrNull()?.takeIf { it > 0 } ?: run {\n                    Toast.makeText(this@MainActivity, \"Ugyldig tetthet for Egendefinert. Bruker standardverdi (2400 kg/m\302\263)\", Toast.LENGTH_SHORT).show()\n                    DENSITY_CONCRETE\n                }\n            }\n            else -> DENSITY_CONCRETE\n        }\n        return volume * density\n    }\n\n        private fun saveCalculationToHistory(context: Context, calculation: String) {\n            val sharedPrefs = context.getSharedPreferences(\"history\", Context.MODE_PRIVATE)\n            val editor = sharedPrefs.edit()\n\n            val currentHistory = sharedPrefs.getString(\"calculations\", \"[]\") ?: \"[]\"\n\n            val jsonArray = try {\n                JSONArray(currentHistory)\n            } catch (e: Exception) {\n                JSONArray()\n            }\n\n            val newCalculation = JSONObject().apply {\n                put(\"calculation\", calculation) // Lagrer hele den formaterte strengen\n                val currentDateTime = LocalDateTime.now()\n                val formatter = DateTimeFormatter.ofPattern(\"yyyy-MM-dd HH:mm:ss\")\n                val formattedDateTime = currentDateTime.format(formatter)\n                put(\"datetime\", formattedDateTime)\n            }\n\n            jsonArray.put(newCalculation)\n\n            while (jsonArray.length() > 20) {\n                jsonArray.remove(0)\n            }\n\n            editor.putString(\"calculations\", jsonArray.toString())\n            editor.apply()\n\n            Log.d(\"History\", \"Saved calculation: $newCalculation\")\n        }\n    }\n```"
  }
  role: USER
}

